.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  width: 100%;
  max-height: 82vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.modal-close {
  font-size: 52rpx;
  color: #999999;
  line-height: 1;
}

.modal-loading,
.modal-error {
  font-size: 28rpx;
  color: #666666;
  padding: 40rpx 0;
}

.modal-content {
  padding-bottom: 20rpx;
}

.word-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
  gap: 14rpx;
}

.meta-line {
  margin-bottom: 8rpx;
}

.word-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #111111;
}

.phonetic-text {
  font-size: 26rpx;
  color: #666666;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 22rpx;
  color: #3f63ff;
}

.play-btn {
  margin: 0;
  background: #f5f7fa;
  color: #2f72ff;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  line-height: 1.2;
}

.section {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 18rpx;
  margin-top: 14rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 8rpx;
}

.line-text {
  font-size: 24rpx;
  color: #444444;
  line-height: 1.7;
  margin-top: 6rpx;
}

.related-card-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eaedf3;
}

.related-card-item:first-child {
  padding-top: 4rpx;
}

.related-card-item:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.related-card-order {
  font-size: 22rpx;
  color: #6f7d95;
}

.related-card-english {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1f2329;
  line-height: 1.5;
}

.related-card-chinese {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5b6370;
  line-height: 1.5;
}
