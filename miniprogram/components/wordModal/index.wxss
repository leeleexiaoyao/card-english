.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-card {
  position: relative;
  width: 100%;
  height: 78vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
}

.modal-mask-opening {
  animation: modal-mask-fade-in 220ms ease-out both;
}

.modal-mask-closing {
  animation: modal-mask-fade-out 220ms ease-in both;
}

.modal-card-opening {
  animation: modal-card-slide-up 260ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.modal-card-closing {
  animation: modal-card-slide-down 220ms cubic-bezier(0.4, 0, 1, 1) forwards;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 20rpx;
  border-bottom: 1rpx solid #eef1f5;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.modal-close {
  font-size: 52rpx;
  color: #999999;
  line-height: 1;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
}

.modal-content {
  padding: 20rpx 18rpx 36rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 180rpx;
}

.hero {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.skeleton-hero {
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
  flex-shrink: 0;
  margin-right: 4rpx;
}

.word-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.phonetic-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.meta-line {
  margin-top: 14rpx;
}

.word {
  font-size: 52rpx;
  font-weight: 700;
  color: #111111;
}

.phonetic {
  font-size: 26rpx;
  color: #666666;
}

.phonetic-play-btn {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.phonetic-play-icon {
  width: 32rpx;
  height: 32rpx;
}

.phonetic-play-icon-blue {
  filter: brightness(0) saturate(100%) invert(40%) sepia(96%) saturate(1836%) hue-rotate(212deg) brightness(99%) contrast(101%);
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 22rpx;
  color: #3f63ff;
}

.favorite-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn.active {
  background: transparent;
}

.favorite-icon {
  width: 40rpx;
  height: 40rpx;
}

.card,
.skeleton-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 10rpx;
}

.line-text {
  font-size: 25rpx;
  color: #3e3e3e;
  line-height: 1.65;
  margin-top: 6rpx;
  white-space: pre-line;
  word-break: break-word;
}

.related-card-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef1f6;
}

.related-card-item:first-child {
  padding-top: 4rpx;
}

.related-card-item:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.related-card-order {
  font-size: 22rpx;
  color: #6f7d95;
}

.related-card-english {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1f2329;
  line-height: 1.5;
  word-break: break-word;
  white-space: normal;
}

.related-card-chinese {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5b6370;
  line-height: 1.5;
  white-space: pre-line;
  word-break: break-word;
}

.highlight-word {
  color: #e53935;
  font-weight: 700;
}

.modal-bottom-action {
  position: absolute;
  right: 0;
  bottom: calc(36rpx + env(safe-area-inset-bottom));
  left: 0;
  z-index: 12;
  display: flex;
  justify-content: center;
  padding: 0 36rpx;
  box-sizing: border-box;
  pointer-events: none;
}

.bottom-learn-btn {
  min-width: 260rpx;
  height: 92rpx;
  padding: 0 24rpx;
  border-radius: 46rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(0, 33, 18, 0.12);
  color: #2a6f57;
  pointer-events: auto;
}

.bottom-learn-btn.active {
  background: #00c07c;
  color: #ffffff;
}

.bottom-learn-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.bottom-learn-label {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

@keyframes modal-mask-fade-in {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes modal-mask-fade-out {
  from {
    opacity: 1;
  }

  to {
    opacity: 0;
  }
}

@keyframes modal-card-slide-up {
  from {
    transform: translateY(100%);
  }

  to {
    transform: translateY(0);
  }
}

@keyframes modal-card-slide-down {
  from {
    transform: translateY(0);
  }

  to {
    transform: translateY(100%);
  }
}

.skeleton-title,
.skeleton-line {
  background: linear-gradient(90deg, #eceff4 0%, #e1e6ee 50%, #eceff4 100%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.2s ease-in-out infinite;
  border-radius: 12rpx;
}

.skeleton-title {
  width: 160rpx;
  height: 32rpx;
}

.skeleton-title-large {
  width: 220rpx;
  height: 48rpx;
}

.skeleton-line {
  width: 100%;
  height: 24rpx;
  margin-top: 16rpx;
}

.skeleton-line-short {
  width: 62%;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -200% 0;
  }
}
