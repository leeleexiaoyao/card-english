.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 18rpx;
  box-sizing: border-box;
}

.filter-row {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 18rpx 28rpx;
  margin-top: 16rpx;
  margin-bottom: 18rpx;
}

.filter-item {
  min-width: 138rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #8b8b8b;
  padding: 8rpx 0 0;
}

.filter-main {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.filter-label {
  font-size: 32rpx;
  line-height: 1.1;
}

.filter-count {
  font-size: 24rpx;
  line-height: 1;
}

.filter-item.active {
  color: #202020;
  font-weight: 600;
}

.filter-indicator {
  width: 64rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: transparent;
}

.filter-item.active .filter-indicator {
  background: #202020;
}

.search-bar {
  margin-bottom: 18rpx;
  padding: 14rpx 18rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #202020;
}

.search-clear {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #3f63ff;
}

.state-text {
  margin-top: 240rpx;
  text-align: center;
  color: #7a7a7a;
  font-size: 28rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.word-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.word-main {
  flex: 1;
  min-width: 0;
}

.word-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.word-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #202020;
}

.phonetic-inline {
  font-size: 22rpx;
  color: #6e6e6e;
}

.pos-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 20rpx;
  color: #3f63ff;
}

.translation-text {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #4a4a4a;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.status-row {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.custom-tag-chip {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(229, 57, 53, 0.12);
  color: #d8433f;
  font-size: 20rpx;
  line-height: 1.2;
}

.tag-text {
  font-size: 22rpx;
  color: #7f8797;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.action-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.audio-icon-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #edf0ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.audio-icon {
  width: 30rpx;
  height: 30rpx;
}

.load-more {
  margin: 12rpx 0 24rpx;
  text-align: center;
  color: #888888;
  font-size: 24rpx;
}
