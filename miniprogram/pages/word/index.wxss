.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 18rpx;
  box-sizing: border-box;
}

.filter-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-bottom: 18rpx;
}

.filter-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  color: #8b8b8b;
  padding: 8rpx 0 0;
}

.filter-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  max-width: 100%;
}

.filter-label {
  font-size: 28rpx;
  line-height: 1.1;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-count {
  font-size: 22rpx;
  line-height: 1;
}

.filter-item.active {
  color: #202020;
  font-weight: 600;
}

.filter-indicator {
  width: 64rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: transparent;
}

.filter-item.active .filter-indicator {
  background: #202020;
}

.search-bar {
  margin-bottom: 18rpx;
  padding: 14rpx 18rpx;
  background: #ffffff;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #202020;
}

.search-clear {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0f2f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear-icon {
  font-size: 28rpx;
  color: #8f97a5;
  line-height: 1;
}

.state-text {
  margin-top: 240rpx;
  text-align: center;
  color: #7a7a7a;
  font-size: 28rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.word-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.word-main {
  flex: 1;
  min-width: 0;
}

.word-title-line {
  line-height: 1.35;
  word-break: break-all;
}

.word-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #202020;
  display: inline;
}

.inline-custom-tag {
  display: inline-flex;
  align-items: center;
  margin-left: 10rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(245, 159, 0, 0.15);
  color: #f08c00;
  font-size: 20rpx;
  line-height: 1.2;
  vertical-align: middle;
}

.word-meta-line {
  margin-top: 6rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.phonetic-inline {
  font-size: 22rpx;
  color: #6e6e6e;
}

.pos-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 20rpx;
  color: #3f63ff;
}

.translation-text {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #4a4a4a;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.custom-tag-chip {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(245, 159, 0, 0.15);
  color: #f08c00;
  font-size: 20rpx;
  line-height: 1.2;
}

.action-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.audio-icon-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.audio-icon {
  width: 32rpx;
  height: 32rpx;
}

.audio-icon-blue {
  filter: brightness(0) saturate(100%) invert(40%) sepia(96%) saturate(1836%) hue-rotate(212deg) brightness(99%) contrast(101%);
}

.load-more {
  margin: 12rpx 0 24rpx;
  text-align: center;
  color: #888888;
  font-size: 24rpx;
}
