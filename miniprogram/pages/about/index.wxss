.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top center, rgba(64, 99, 255, 0.08), transparent 26%),
    linear-gradient(180deg, #f8f4ef 0%, #f3f5f8 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.placeholder-card {
  height: 280rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.75);
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.05);
}
