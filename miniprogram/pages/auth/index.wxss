.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(circle at top, rgba(4, 120, 245, 0.18), transparent 38%),
    linear-gradient(180deg, #f8fbff 0%, #eef4fb 100%);
}

.panel {
  width: 100%;
  padding: 56rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 24rpx 64rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.badge {
  align-self: flex-start;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(4, 120, 245, 0.1);
  color: #0478f5;
  font-size: 22rpx;
  font-weight: 600;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #0f172a;
}

.desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #475569;
}

.login-btn {
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #0478f5;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
