.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 8px 18rpx 18rpx 8px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.05);
}

.profile-card {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin: 0;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #e9eaed;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: 92rpx;
  overflow: hidden;
  display: block;
  padding: 0;
  margin: 0;
}

.profile-main {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e1e1e;
  text-align: left;
}

.editable-name {
  position: relative;
}

.editable-name::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -6rpx;
  height: 2rpx;
  background: rgba(4, 120, 245, 0.22);
}

.name-input {
  min-width: 220rpx;
  height: 52rpx;
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  font-size: 32rpx;
  font-weight: 600;
  color: #1e1e1e;
  line-height: 52rpx;
  text-align: left;
}

.role-tag {
  min-width: 100rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(47, 114, 255, 0.12);
  color: #2f72ff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.role-tag.vip {
  background: rgba(255, 136, 41, 0.14);
  color: #ff8829;
}

.role-tag-block {
  min-width: 0;
}

.profile-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.login-btn,
.avatar-picker {
  margin: 0;
}

.profile-avatar-picker {
  width: 92rpx;
  min-width: 92rpx;
  height: 92rpx;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
  line-height: 0;
  font-size: 0;
  flex-shrink: 0;
  flex-grow: 0;
  flex-basis: 92rpx;
  display: block;
}

.profile-avatar-picker::after {
  border: 0;
}

.login-btn {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: #0478f5;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.2;
}

.profile-more {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.setting-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.member-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 223, 171, 0.26), transparent 36%),
    linear-gradient(135deg, #1c2233 0%, #2f2239 100%);
  color: #ffffff;
}

.member-badge {
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
}

.member-title {
  font-size: 40rpx;
  font-weight: 700;
}

.member-desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
}

.member-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.member-meta {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.member-link {
  min-width: 160rpx;
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #1e2434;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.section-title {
  margin-top: 20rpx;
  padding: 6rpx 4rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #2f2f2f;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.row-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.row-title {
  font-size: 28rpx;
  color: #222222;
}

.row-sub {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.row-value {
  font-size: 26rpx;
  color: #cccccc;
}

.clickable {
  padding: 8rpx 0;
}

.picker-value {
  color: #cccccc;
}

.row-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: flex-end;
}

.more-arrow {
  width: 48rpx;
  height: 48rpx;
  object-fit: contain;
}
