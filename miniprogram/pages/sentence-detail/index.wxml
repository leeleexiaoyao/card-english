<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{error}}" class="state-text">{{error}}</view>

  <sentence-card-viewer
    wx:elif="{{currentSentence}}"
    sentences="{{sentences}}"
    currentSentence="{{currentSentence}}"
    counts="{{counts}}"
    currentIndex="{{currentIndex}}"
    swiperCurrent="{{swiperCurrent}}"
    imageHintDismissed="{{imageHintDismissed}}"
    showTopActions="{{true}}"
    defaultShowChinese="{{settings.defaultShowChinese}}"
    audioAutoPlayMode="{{settings.audioAutoPlayMode}}"
    bind:swiperchange="onSwiperChange"
    bind:tapimage="onTapImage"
    bind:playsentenceaudio="onPlaySentenceAudio"
    bind:playchineseaudio="onPlayChineseAudio"
    bind:tapword="onTapWord"
    bind:goback="onGoBack"
    bind:markunmastered="onMarkUnmastered"
    bind:markmastered="onMarkMastered"
    bind:togglefavorited="onToggleFavorited"
    bind:toggledefaultshowchinese="onToggleDefaultShowChinese"
    bind:copyenglish="onCopyEnglish"
    bind:cycleaudioplaymode="onCycleAudioPlayMode"
  />

  <word-modal
    visible="{{wordModalVisible}}"
    loading="{{wordModalLoading}}"
    error="{{wordModalError}}"
    detail="{{wordDetail}}"
    showRelatedCards="{{false}}"
    isVip="{{wordMarkMeta.isVip}}"
    customWordTagName="{{wordMarkMeta.customWordTagName}}"
    queryWord="{{wordQuery}}"
    bind:close="onCloseWordModal"
    bind:opencard="onOpenWordCard"
    bind:playaudio="onPlayWordAudio"
    bind:togglefavorite="onToggleWordFavorite"
    bind:togglecustomtag="onToggleWordCustomTag"
  />
</view>
