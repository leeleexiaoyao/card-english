<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{error}}" class="state-text">{{error}}</view>

  <view wx:elif="{{currentSentence}}" class="content">
    <view class="card-stage">
      <swiper
        class="card-swiper"
        current="{{swiperCurrent}}"
        duration="320"
        easing-function="easeOutCubic"
        skip-hidden-item-layout="{{true}}"
        enable-back-to-top="{{false}}"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{sentences}}" wx:key="_id">
          <view class="card-slide">
            <view class="card-shell" bindtap="onTapImage" data-index="{{index}}">
              <image class="card-bg" src="{{item.resolvedImageUrl}}" mode="aspectFill" bindload="onImageLoad" binderror="onImageError" />
              <view class="card-overlay"></view>
              <view class="top-actions">
                <image class="icon-btn" wx:if="{{currentIndex === index}}" src="/assets/icon/icon_sound_open.svg" catchtap="onPlaySentenceAudio" />
                <image class="icon-btn" wx:if="{{currentIndex === index}}" src="{{currentSentence.favorited ? '/assets/icon/icon_uncollect.svg' : '/assets/icon/icon_collect.svg'}}" catchtap="onToggleFavorited" />
              </view>

              <view class="card-bottom" catchtap="noop">
                <view class="card-bottom-mask"></view>
                <view class="card-bottom-content">
                  <view class="top-content" style="transform: translateY({{item.showChinese ? '0' : '20rpx'}}); transition: transform 0.3s ease-in-out;">
                    <text class="progress">{{(index + 1) < 10 ? '0' + (index + 1) : (index + 1)}}/{{counts.total}}</text>
                    <view class="sentence-line">
                      <block wx:for="{{item.englishTokens}}" wx:key="index">
                        <text wx:if="{{item.isWord}}" space="ensp" class="word-token" catchtap="onTapWord" data-word="{{item.word}}">{{item.text}}</text>
                        <text wx:else space="ensp" class="plain-token">{{item.text}}</text>
                      </block>
                    </view>
                  </view>
                  <view class="chinese-line-container" style="height: {{item.showChinese ? 'auto' : '0'}}; opacity: {{item.showChinese ? '1' : '0'}}; transform: translateY({{item.showChinese ? '0' : '20rpx'}});">
                    <view wx:if="{{item.showChinese}}" class="chinese-line">{{item.chinese}}</view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="bottom-actions">
      <image class="nav-btn" src="/assets/icon/icon_previous.svg" bindtap="goPrev" />
      <view class="master-btn {{currentSentence.mastered ? 'mastered' : ''}}" bindtap="onToggleMastered">
        {{currentSentence.mastered ? '已掌握' : '未掌握'}}
      </view>
      <image class="nav-btn" src="/assets/icon/icon_next.svg" bindtap="goNext" />
    </view>
  </view>

  <word-modal
    visible="{{wordModalVisible}}"
    loading="{{wordModalLoading}}"
    error="{{wordModalError}}"
    detail="{{wordDetail}}"
    bind:close="onCloseWordModal"
    bind:playaudio="onPlayWordAudio"
  />
</view>
