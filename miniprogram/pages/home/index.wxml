<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{error}}" class="state-text">{{error}}</view>

  <view wx:elif="{{currentSentence}}" class="content">
    <view class="card-stage" catchtouchmove="noop">
      <swiper
        class="card-swiper"
        current="{{swiperCurrent}}"
        duration="320"
        easing-function="easeOutCubic"
        skip-hidden-item-layout="{{true}}"
        enable-back-to-top="{{false}}"
        disable-touch="{{true}}"
        bindchange="onSwiperChange"
      >
        <swiper-item wx:for="{{sentences}}" wx:key="_id">
          <view class="card-slide">
            <view class="card-shell" bindtap="onTapImage" data-index="{{index}}">
              <image class="card-bg" src="{{item.resolvedImageUrl}}" mode="widthFix" bindload="onImageLoad" binderror="onImageError" />
              <view class="card-overlay"></view>
              <view class="top-actions">
                <image class="icon-btn" wx:if="{{currentIndex === index}}" src="/assets/icon/icon_sound_open.svg" catchtap="onPlaySentenceAudio" />
                <image class="icon-btn" wx:if="{{currentIndex === index}}" src="{{item.favorited ? '/assets/icon/icon_uncollect.svg' : '/assets/icon/icon_collect.svg'}}" catchtap="onToggleFavorited" />
              </view>

              <view class="card-bottom" catchtap="noop">
                <view class="card-bottom-mask"></view>
                <view class="card-bottom-content {{item.showChinese ? 'content-expanded' : 'content-collapsed'}}">
                  <text class="progress">{{(index + 1) < 10 ? '0' + (index + 1) : (index + 1)}}/{{counts.total}}</text>
                  <view class="sentence-line">
                    <block wx:for="{{item.englishTokens}}" wx:key="index">
                      <text wx:if="{{item.isWord}}" space="ensp" class="word-token" catchtap="onTapWord" data-word="{{item.word}}">{{item.text}}</text>
                      <text wx:else space="ensp" class="plain-token">{{item.text}}</text>
                    </block>
                  </view>
                  <view wx:if="{{item.chinese}}" class="chinese-line">
                    <text class="chinese-text" catchtap="onPlayChineseAudio" data-text="{{item.chinese}}">{{item.chinese}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view class="bottom-actions">
      <view class="action-btn action-btn-back {{currentIndex === 0 ? 'action-btn-disabled' : ''}}" bindtap="onGoBack">
        返回
      </view>
      <view class="action-btn action-btn-mastered {{currentSentence && currentSentence.mastered === true ? 'action-btn-active' : ''}}" bindtap="onMarkMastered">
        已掌握
      </view>
      <view class="action-btn action-btn-unmastered {{currentSentence && currentSentence.mastered === false ? 'action-btn-active' : ''}}" bindtap="onMarkUnmastered">
        未掌握
      </view>
    </view>

    <view wx:if="{{!imageHintDismissed}}" class="image-hint">提示：点击图片可查看释义</view>
  </view>

  <word-modal
    visible="{{wordModalVisible}}"
    loading="{{wordModalLoading}}"
    error="{{wordModalError}}"
    detail="{{wordDetail}}"
    queryWord="{{wordQuery}}"
    bind:close="onCloseWordModal"
    bind:opencard="onOpenWordCard"
    bind:playaudio="onPlayWordAudio"
  />
</view>
