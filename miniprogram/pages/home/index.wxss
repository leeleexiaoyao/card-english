.page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 0;
  box-sizing: border-box;
}

.state-text {
  margin-top: 240rpx;
  padding: 0 24rpx;
  text-align: center;
  color: #7a7a7a;
  font-size: 28rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-stage {
  width: 100%;
  background: transparent;
}

.card-swiper {
  height: 980rpx;
  background: transparent;
}

.card-swiper swiper-item {
  background: transparent;
}

.card-slide {
  box-sizing: border-box;
  height: 100%;
  padding: 0 24rpx;
}

.card-shell {
  position: relative;
  height: 980rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 72rpx rgba(17, 24, 39, 0.16);
  background: #2f3238;
}

.card-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: auto;
  display: block;
}

.card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(9, 14, 26, 0.08) 0%, rgba(9, 14, 26, 0.28) 100%);
}

.card-bottom {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 3;
  color: #ffffff;
  overflow: hidden;
}

.card-bottom-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0) 0%,
    rgba(0, 0, 0, 0.08) 42%,
    rgba(0, 0, 0, 0.76) 100%
  );
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.card-bottom-content {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 12rpx;
  padding: 0 24rpx 32rpx;
}

.progress,
.sentence-line,
.chinese-line {
  transition: transform 280ms ease, opacity 280ms ease, max-height 280ms ease, margin-top 280ms ease;
}

.progress {
  font-size: 24rpx;
  opacity: 0.96;
}

.progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-audio-btn {
  width: 58rpx;
  height: 58rpx;
  padding: 12rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  box-sizing: border-box;
  flex-shrink: 0;
}

.sentence-line {
  margin-top: 16rpx;
  font-size: 38rpx;
  line-height: 1.38;
  font-weight: 600;
  word-break: break-word;
}

.plain-token {
  color: #ffffff;
}

.word-token {
  color: #ffffff;
}

.chinese-line {
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 1.48;
  opacity: 0;
  max-height: 0;
  overflow: hidden;
  transform: translateY(18rpx);
}

.chinese-text {
  display: block;
}

.card-bottom-content.content-collapsed .progress,
.card-bottom-content.content-collapsed .sentence-line {
  transform: translateY(12rpx);
}

.card-bottom-content.content-expanded .progress,
.card-bottom-content.content-expanded .sentence-line {
  transform: translateY(0);
}

.card-bottom-content.content-expanded .chinese-line {
  margin-top: 16rpx;
  opacity: 0.96;
  max-height: 240rpx;
  transform: translateY(0);
}

.card-bottom-content.content-collapsed .chinese-line {
  margin-top: 0;
  opacity: 0;
  max-height: 0;
  transform: translateY(18rpx);
}

.bottom-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 36rpx 24rpx;
}

.image-hint {
  width: 100%;
  padding: 0 36rpx 28rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  box-sizing: border-box;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(17, 24, 39, 0.08);
}

.action-btn-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  flex-shrink: 0;
}

.action-btn-wide {
  flex: 1;
  height: 88rpx;
  border-radius: 26rpx;
  gap: 10rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.action-icon {
  width: 34rpx;
  height: 34rpx;
  object-fit: contain;
}

.action-icon-small {
  width: 32rpx;
  height: 32rpx;
}

.action-symbol {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
}

.action-label {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 600;
}

.action-btn-mastered,
.action-btn-unmastered {
  transition: background 180ms ease, color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
}

.action-btn-mastered {
  color: #333333;
}

.action-btn-unmastered {
  color: #333333;
}

.action-btn-mastered.action-btn-active {
  background: #0ea5e9;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(14, 165, 233, 0.24);
}

.action-btn-unmastered.action-btn-active {
  background: #fb7185;
  color: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(251, 113, 133, 0.24);
}

.action-btn-favorited {
  background: #fff1f5;
}

.action-btn-disabled {
  opacity: 0.4;
}

.action-btn-disabled .action-icon {
  opacity: 0.5;
}
