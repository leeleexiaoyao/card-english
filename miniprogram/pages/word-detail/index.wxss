.page {
  min-height: 100vh;
  background: #f4f5f7;
  padding: 18rpx;
  box-sizing: border-box;
}

.state-text {
  margin-top: 220rpx;
  text-align: center;
  color: #7a7a7a;
  font-size: 28rpx;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hero {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  flex-shrink: 0;
}

.word-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.phonetic-line {
  margin-top: 6rpx;
}

.meta-line {
  margin-top: 14rpx;
}

.word {
  font-size: 52rpx;
  font-weight: 700;
  color: #111111;
}

.phonetic {
  font-size: 26rpx;
  color: #666666;
}

.meta-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef3ff;
  font-size: 22rpx;
  color: #3f63ff;
}

.favorite-btn {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  border: 1rpx solid #d4d9e2;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn.active {
  border-color: #2f72ff;
  background: #edf3ff;
}

.favorite-icon {
  width: 34rpx;
  height: 34rpx;
}

.custom-tag-btn {
  min-width: 130rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d4d9e2;
  color: #637186;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #ffffff;
  gap: 6rpx;
}

.custom-tag-btn.active {
  border-color: #e53935;
  color: #e53935;
  background: rgba(229, 57, 53, 0.1);
}

.custom-tag-plus {
  font-size: 26rpx;
  line-height: 1;
  font-weight: 600;
}

.custom-tag-label {
  font-size: 22rpx;
  line-height: 1;
}

.play-btn {
  width: 74rpx;
  height: 74rpx;
  border-radius: 50%;
  background: #edf2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-icon {
  width: 34rpx;
  height: 34rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222222;
  margin-bottom: 10rpx;
}

.line-text {
  font-size: 25rpx;
  color: #3e3e3e;
  line-height: 1.65;
  margin-top: 6rpx;
}

.related-card-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef1f6;
}

.related-card-item:first-child {
  padding-top: 4rpx;
}

.related-card-item:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.related-card-order {
  font-size: 22rpx;
  color: #6f7d95;
}

.related-card-english {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1f2329;
  line-height: 1.5;
}

.related-card-chinese {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #5b6370;
  line-height: 1.5;
}

.highlight-word {
  color: #e53935;
  font-weight: 700;
}
