<view class="page">
  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{error}}" class="state-text">{{error}}</view>

  <view wx:elif="{{detail}}" class="content">
    <view class="hero">
      <view class="hero-main">
        <view class="word-line">
          <text class="word">{{detail.word}}</text>
        </view>
        <view wx:if="{{detail.phonetic}}" class="phonetic-line">
          <text class="phonetic">{{detail.phonetic}}</text>
        </view>
        <view wx:if="{{detail.posText}}" class="meta-line">
          <text class="meta-tag">{{detail.posText}}</text>
        </view>
      </view>
      <view class="hero-actions">
        <view class="action-btn {{detail.favorited ? 'active' : ''}}" bindtap="onToggleFavorite">收藏</view>
        <view
          wx:if="{{isVip}}"
          class="action-btn {{detail.customTagged ? 'active custom' : ''}}"
          bindtap="onToggleCustomTag"
        >
          {{customWordTagName}}
        </view>
        <view wx:if="{{detail.audio}}" class="play-btn" bindtap="onPlayAudio">
          <text class="play-icon-text">播</text>
        </view>
      </view>
    </view>

    <view wx:if="{{detail.definitionText}}" class="card">
      <view class="card-title">英文释义</view>
      <view class="line-text">{{detail.definitionText}}</view>
    </view>

    <view wx:if="{{detail.translationText || detail.chineseMeaning}}" class="card">
      <view class="card-title">中文释义</view>
      <view class="line-text">{{detail.translationText || detail.chineseMeaning}}</view>
    </view>

    <view wx:if="{{detail.tagText}}" class="card">
      <view class="card-title">标签</view>
      <view class="line-text">{{detail.tagText}}</view>
    </view>

    <view wx:if="{{detail.exchangeText || detail.forms.length}}" class="card">
      <view class="card-title">词形变化</view>
      <view wx:if="{{detail.exchangeText}}" class="line-text">{{detail.exchangeText}}</view>
      <view wx:elif="{{detail.forms.length}}">
        <view wx:for="{{detail.forms}}" wx:key="label" class="line-text">{{item.label}}：{{item.value}}</view>
      </view>
    </view>

    <view wx:if="{{detail.hasRelatedCards}}" class="card">
      <view class="card-title">卡片释义</view>
      <view
        wx:for="{{detail.relatedCards}}"
        wx:key="id"
        class="related-card-item"
        data-id="{{item.id}}"
        bindtap="onTapRelatedCard"
      >
        <view class="related-card-order">卡片 {{item.order}}</view>
        <view class="related-card-english">
          <text
            wx:for="{{item.englishSegments}}"
            wx:key="index"
            wx:for-item="segment"
            class="{{segment.highlighted ? 'highlight-word' : ''}}"
          >
            {{segment.text}}
          </text>
        </view>
        <view class="related-card-chinese">{{item.chinese}}</view>
      </view>
    </view>
  </view>
</view>
